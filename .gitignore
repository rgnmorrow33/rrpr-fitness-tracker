# Device-local Claude Code files stay ignored; the shared hook config
# (.claude/settings.json) is tracked so enforcement survives this machine.
.claude/*
!.claude/settings.json
*.csv
supabase/

# Local env / credentials - never commit. .env.example is the only tracked one.
.env
.env.*
!.env.example

# Playwright smoke suite
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/results.json

# Python bytecode - rectrac-import tooling is tracked, its bytecode is not
__pycache__/
*.pyc
*.pyo

# OS / editor cruft
.DS_Store

# Stray root copy of the embedded-JS syntax check (hook writes to os.tmpdir)
# and generic temp files
.embedded-check.js
*.tmp
