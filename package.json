{
  "name": "rrpr-fitness-tracker-smoke",
  "version": "1.0.0",
  "private": true,
  "description": "Read-only post-deploy smoke suite for the Round Rock Fitness Tracker. Does not build or bundle the app (single-file HTML, no build step); this package only carries the Playwright test harness.",
  "scripts": {
    "test": "playwright test",
    "test:local": "playwright test -c playwright.local.config.ts",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "log:scaffold": "node scripts/log-scaffold.js",
    "release:tag": "node scripts/release-tag.js",
    "schema:check": "node --env-file-if-exists=.env scripts/schema-check.js",
    "serve:staging": "node scripts/serve-staging.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "pg": "^8.21.0"
  }
}
